# .dockerignore - Roadmap App
# Ignorar arquivos desnecessários no build do Docker

# Dependências
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Arquivos de build local
dist
build
.next
.nuxt
.cache
.temp
.tmp

# Arquivos de ambiente
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory usado por tools como istanbul
coverage
*.lcov

# Diretório de instrumentação do nyc
.nyc_output

# Dependency directories
jspm_packages/

# Diretórios opcionais de cache do npm
.npm

# Diretório de cache do yarn
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Arquivo de dependências para zero-installs do yarn
!.yarn/cache

# Arquivo de sessão ESLint
.eslintcache

# Arquivo de cache do Prettier
.prettiercache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Diretório de saída do FUSE-box
.fusebox/

# Arquivos locais do DynamoDB
.dynamodb/

# Porta do TernJS
.tern-port

# Stores VSCode versions usado para testes
.vscode-test

# Pasta do yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Git
.git
.gitignore
.gitattributes

# Docker
Dockerfile*
docker-compose*
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
.circleci

# Documentação
README.md
docs/
*.md

# Arquivos de teste
test/
tests/
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# Editor/IDE
.idea
.vscode
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Prisma
prisma/migrations/