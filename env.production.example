# env.production.example - Roadmap App
# Configurações para ambiente de produção
# IMPORTANTE: Copie para .env e altere os valores padrão!

# Database Configuration
DATABASE_URL="mysql://roadmap_user:roadmap_password_change_me@mysql:3306/roadmap_db"
MYSQL_ROOT_PASSWORD="root_password_change_me"
MYSQL_PASSWORD="roadmap_password_change_me"

# Application Configuration
NODE_ENV="production"
PORT="3000"

# Security Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production-must-be-very-long-and-secure"
JWT_EXPIRES_IN="7d"

# Cache Configuration (Optional)
REDIS_URL="redis://redis:6379"

# Logging
LOG_LEVEL="error"

# CORS Configuration
CORS_ORIGIN="https://your-domain.com"

# Rate Limiting
THROTTLE_TTL="60000"
THROTTLE_LIMIT="100"

# Performance
CACHE_TTL="60000"
CACHE_MAX="100"

# Health Check
HEALTH_CHECK_ENABLED="true"

# Prisma
PRISMA_GENERATE_DATAPROXY="false"
